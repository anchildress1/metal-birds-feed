# Cloudflare R2 — S3-compatible credentials for the private aircraft registry bucket.
# These are required for the refresh pipeline to write to R2.
# Get them from: Cloudflare Dashboard → R2 → Manage R2 API tokens
MBF_R2_ACCOUNT_ID=
MBF_R2_ACCESS_KEY_ID=
MBF_R2_SECRET_ACCESS_KEY=
MBF_R2_BUCKET_NAME=

# Pipeline behaviour (optional overrides for local development)
# Source to refresh. Leave empty to refresh all configured sources.
REFRESH_SOURCE=

# Set to "true" to translate and diff without writing to R2.
DRY_RUN=false
